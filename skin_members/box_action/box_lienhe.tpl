<div class="box_out_table">
    <div class="title">Thông tin liên hệ</div>
    <div>
        <table class="bang_info" max-width="768">
            <tr>
                <td class="text" width="250">Công ty</td>
                <td class="info">{cong_ty}</td>
            </tr>
            <tr class="blank">
                <td colspan="2"></td>
            </tr>
            <tr>
                <td width="180" class="text">Họ và tên</td>
                <td class="info">{name}</td>
            </tr>
            <tr class="blank">
                <td colspan="2"></td>
            </tr>
            <tr>
                <td class="text">Điện thoại</td>
                <td class="info">{mobile}</td>
            </tr>
            <tr class="blank">
                <td colspan="2"></td>
            </tr>
            <tr>
                <td class="text">Chat</td>
                <td class="info"><button class="bg_green" name="show_chat" id="{user_id}"><i class="fa fa-comment-o"></i> Chat</button></td>
            </tr>
        </table>
    </div>
</div>