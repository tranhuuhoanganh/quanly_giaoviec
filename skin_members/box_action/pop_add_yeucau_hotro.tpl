<div class="box_pop_add_content pop_add_lienhe" style="width: 450px;">
    <div class="pop_title">
        <h5>Yêu cầu hỗ trợ</h5>
        <span><i class="fa fa-close"></i></span>
    </div>
    <div class="pop_content">
        <div class="li_input">
            <label>Bộ phận hỗ trợ</label>
            <select name="quy_trinh">
                <option value="">Chọn bộ phận hỗ trợ</option>
                <option value="hotro_chung">Hỗ trợ chung</option>
                <option value="booking">Hỗ trợ booking</option>
                <option value="tai_chinh">Hỗ trợ tài chính</option>
            </select>
        </div>
        <div class="li_input">
            <label>Chủ đề yêu cầu</label>
            <textarea name="noi_dung" autocomplete="off"></textarea>
            <input type="hidden" name="thanh_vien" value="{thanh_vien}">
        </div>
    </div>
    <div class="pop_button">
        <div class="button_left">
        </div>
        <div class="button_center">
            <button id="cancel">Hủy</button>
            <button class="bg_green" name="gui_ykien">Thực hiện</button>
        </div>
        <div class="button_right">
        </div>
    </div>
</div>