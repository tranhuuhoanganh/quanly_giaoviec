<tr class="tr_{id}">
    <td>{i}</td>
    <td><img src="{logo}" width="100"></td>
    <td>{viet_tat}</td>
    <td>{tieu_de}</td>
    <td>{link}</td>
    <td class="sticky-column">
        <button class="bg_blue b_mobile" onclick="show_edit('hangtau','{id}');"><i class="fa fa-pencil-square-o"></i> Sửa</button>
        <button class="bg_red b_mobile" onclick="del('hangtau','{id}');"><i class="fa fa-trash-o"></i> Xóa</button>
    </td>
</tr>
<tr class="tr_{id}">
	<td colspan="5"></td>
</tr>