<div class="li_rate">
    <div class="avatar_rate">
        <img src="{avatar}" onerror="this.src='/images/user.png'">
    </div>
    <div class="info_rate">
        <div class="name">{name} - {mobile}</div>
        <div class="list_star">
            {list_star}
        </div>
        <div class="note">{note}</div>
        <div class="time_rate">
            <div class="time">{text_rate}: {update_post}</div>
        </div>
    </div>
</div>