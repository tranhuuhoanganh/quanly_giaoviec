{header}
<body class="body_scroll">
	{box_header}
	<div class="box_contact" style="padding-top: 80px;">
		<div class="box_contact_container">
			<div class="box_img">
				<img src="/images/giaoviec2-removebg-preview.png">
			</div>
			<div class="form_contact">
				<div class="title_box hide_success">Lấy lại mật khẩu đăng nhập</div>
				<div class="li_input hide_success">
					<input type="text" name="email" autocomplete="off" placeholder="Email hoặc số điện thoại*">
				</div>
				<div class="li_input hide_success">
					<button name="quen_matkhau">Lấy lại mật khẩu</button>
				</div>
				<div class="li_input hide_success">
					<div class="text-center" style="font-size: 12px;font-style: italic;color: #f00;font-weight: 700;width: 100%;">
						Hãy nhập đúng số điện thoại hoặc email dùng đăng ký tài khoản!<br>
						Mật khẩu sẽ được gửi tới email đăng ký tài khoản.
					</div>
				</div>
				<div class="li_input show_success">
					<div class="text-center">
						<div class="note_success"><i class="fa fa-check-circle"></i></div>
						<div class="note_naptien">Gửi yêu cầu thành công!</div>
						<div class="note2_naptien">
						Link thiết lập mật khẩu mới đã được gửi tới địa chỉ email:<br>
						<span class="email_address">xahoigiaitri@gmail.com</span><br>
						Vui lòng truy cập email để thiết lập mật khẩu.
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	{footer}
	{script_footer}
</body>
</html>