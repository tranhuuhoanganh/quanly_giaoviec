				</div>
				<div class="li_input">
					<div class="text-center" style="width: 100%;">
						<a href="/dang-ky.html">Đăng ký</a> | <a href="/quen-mat-khau.html">Quên mật khẩu?</a>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- {footer} -->
	{script_footer}
</body>
</html>