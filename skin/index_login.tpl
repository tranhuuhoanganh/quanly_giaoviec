{header}
<body class="body_scroll">
	{box_header}
	<div class="top_home_login">
		<div class="top_home_login_container">
			<div class="form_timkiem">
				<div class="li_input">
					<div class="text">Loại hình</div>
					<div class="select">
						<select name="loai_hinh">
							<option>Chọn loại hình</option>
						</select>
					</div>
				</div>
				<div class="li_input">
					<div class="text">Hãng tàu</div>
					<div class="select">
						<select name="hang_tau">
							<option>Chọn hãng tàu</option>
						</select>
					</div>
				</div>
				<div class="li_input">
					<div class="text">Loại container</div>
					<div class="select">
						<select>	
							<option>Chọn loại container</option>
						</select>
					</div>
				</div>
				<div class="button_search">
					<button><i class="fa fa-search"></i> Tìm kiếm</button>
				</div>
			</div>
		</div>
	</div>
	<div class="home_login">
		<div class="home_login_container">
			<div class="home_login_left">
				<div class="box_home_login_left">
					<div class="title">Giá</div>
					<div></div>
				</div>
				<div class="box_home_login_left">
					<div class="title">Đánh giá</div>
					<div class="list_danhgia"></div>
				</div>
			</div>
			<div class="home_login_right">
				<div class="box_home_login_right">
					<div class="minh_hoa"></div>
					<div class="info">
						<div class="tieu_de"></div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="box_lienhe">
		<div class="box_lienhe_container">
			<div class="title_box">KNCV luôn lắng nghe</div>
			<div class="list_box_lienhe">
				<div class="li_box_lienhe">
					<div class="tieu_de"><div class="icon_lienhe"><img src="/skin/css/images/icon_hotline.png"></div>Hotline</div>
					<div class="mo_ta">
						Chăm sóc khách hàng: 0962.892.846<br>
						Hoạt động 365 ngày/năm từ 7:00 đến 22:00 kể cả ngày nghỉ lễ, tết.
					</div>
				</div>
				<div class="li_box_lienhe">
					<div class="tieu_de"><div class="icon_lienhe"><img src="/skin/css/images/icon_zalo.png"></div>KNVC Zalo</div>
					<div class="mo_ta">
						Luôn trả lời các thông tin nhanh nhất thông qua các phản hồi trên Zalo.
					</div>
				</div>
				<div class="li_box_lienhe">
					<div class="tieu_de"><div class="icon_lienhe"><img src="/skin/css/images/icon_chat.png"></div>Chat trên web & mobile</div>
					<div class="mo_ta">
						Luôn có người trực chat để trả lời câu hỏi của các bạn nhanh và hiệu quả nhất suốt 365 ngày/năm.
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="box_contact">
		<div class="box_contact_container">
			<div class="box_img">
				<img src="/skin/css/images/contact.png">
			</div>
			<div class="form_contact">
				<div class="title_box">Hãy để KNVC được hỗ trợ bạn</div>
				<div class="li_input">
					<input type="text" name="ho_ten" placeholder="Họ và tên*">
				</div>
				<div class="li_input">
					<input type="text" name="email" placeholder="Email*">
				</div>
				<div class="li_input">
					<input type="text" name="dien_thoai" placeholder="Số điện thoại*">
				</div>
				<div class="li_input">
					<textarea placeholder="Lĩnh vực của bạn" name="linh_vuc"></textarea>
				</div>
				<div class="li_input">
					<button name="dangky_nhantin">Đăng ký nhận thông tin yêu cầu tư vấn</button>
				</div>
			</div>
		</div>
	</div>
	{footer}
	{script_footer}
</body>
</html>