{header}
<body class="body_scroll">
	{box_header}
	<div class="box_contact" style="padding-top: 80px;">
		<div class="box_contact_container">
			<div class="box_img">
				<img src="/images/giaoviec2-removebg-preview.png">
			</div>
			<div class="form_contact">
				<div class="title_box hide_success">Đăng ký tài khoản</div>
				
				<div class="li_input hide_success">
					<input type="text" name="ho_ten" placeholder="Họ và tên*" autocomplete="off">
				</div>
				<div class="li_group_input hide_success">
					<div class="li_input hide_success">
						<input type="text" name="dien_thoai" placeholder="Điện thoại*" autocomplete="off">
					</div>
					<div class="li_input hide_success">
						<input type="text" name="email" placeholder="Email*" autocomplete="off">
					</div>
				</div>
				<div class="li_group_input hide_success">
					<div class="li_input hide_success">
						<input type="password" name="password" placeholder="Mật khẩu*" autocomplete="off">
					</div>
					<div class="li_input hide_success">
						<input type="password" name="re_password" placeholder="Nhập lại mật khẩu*" autocomplete="off">
					</div>
				</div>
				
				<div class="li_input hide_success">
					<button name="dangky_taikhoan">Đăng Ký</button>
				</div>
				<div class="li_input hide_success">
					<div class="text-center" style="width: 100%;">
						<a href="/dang-nhap.html">Đăng nhập</a> | <a href="/quen-mat-khau.html">Quên mật khẩu?</a>
					</div>
				</div>
				<div class="li_input show_success">
					<div class="text-center">
						<div class="note_success"><i class="fa fa-check-circle"></i></div>
						<div class="note_naptien">Đăng ký tài khoản thành công!</div>
						<div class="note2_naptien">
						Yêu cầu của bạn đã được gửi đến chúng tôi!<br>
						<!-- <span class="email_address">xahoigiaitri@gmail.com</span><br> -->
						Chúng tôi sẽ liên hệ lại để xác nhận.
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	{footer}
	{script_footer}
</body>
</html>